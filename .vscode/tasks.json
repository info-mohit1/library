{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install dependencies",
      "type": "shell",
      "command": "pnpm install",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "bookverse"
      },
      "problemMatcher": []
    },
    {
      "label": "Start API Server",
      "type": "shell",
      "command": "pnpm --filter @workspace/api-server run dev:local",
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "bookverse"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Server listening"
        }
      }
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "pnpm --filter @workspace/bookverse run dev:local",
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "bookverse"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "ready in"
        }
      },
      "dependsOn": ["Start API Server"]
    },
    {
      "label": "BookVerse: Start All",
      "dependsOn": ["Start API Server", "Start Frontend"],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Push DB Schema",
      "type": "shell",
      "command": "pnpm --filter @workspace/db run push",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Seed Database",
      "type": "shell",
      "command": "pnpm --filter @workspace/db run seed",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
